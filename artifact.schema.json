{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/schemas/artifact.schema.json",
  "title": "Artifact",
  "type": "object",
  "required": ["artifact_id", "task_id", "trace_id", "kind", "uri", "created_at"],
  "properties": {
    "artifact_id": {
      "type": "string",
      "pattern": "^art_[a-z0-9]{8,64}$"
    },
    "task_id": {
      "type": "string",
      "pattern": "^task_[a-z0-9]{8,64}$"
    },
    "trace_id": {
      "type": "string",
      "pattern": "^trace_[a-z0-9]{8,64}$"
    },
    "step_id": {
      "type": "string",
      "pattern": "^step_[a-z0-9]{8,64}$"
    },
    "kind": {
      "type": "string",
      "enum": ["patch", "log", "report", "binary", "other"]
    },
    "uri": {
      "type": "string",
      "format": "uri"
    },
    "checksum_sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true,
      "default": {}
    }
  },
  "additionalProperties": false
}
