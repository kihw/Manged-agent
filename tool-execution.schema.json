{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/schemas/tool-execution.schema.json",
  "title": "ToolExecution",
  "type": "object",
  "required": ["tool_call_id", "task_id", "trace_id", "step_id", "tool_name", "status", "started_at"],
  "properties": {
    "tool_call_id": {
      "type": "string",
      "pattern": "^tool_[a-z0-9]{8,64}$"
    },
    "task_id": {
      "type": "string",
      "pattern": "^task_[a-z0-9]{8,64}$"
    },
    "trace_id": {
      "type": "string",
      "pattern": "^trace_[a-z0-9]{8,64}$"
    },
    "step_id": {
      "type": "string",
      "pattern": "^step_[a-z0-9]{8,64}$"
    },
    "tool_name": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "$ref": "#/$defs/task_status"
    },
    "input_redacted": {
      "type": "object",
      "additionalProperties": true,
      "default": {}
    },
    "output_redacted": {
      "type": "object",
      "additionalProperties": true,
      "default": {}
    },
    "started_at": {
      "type": "string",
      "format": "date-time"
    },
    "ended_at": {
      "type": ["string", "null"],
      "format": "date-time"
    },
    "duration_ms": {
      "type": ["integer", "null"],
      "minimum": 0
    }
  },
  "$defs": {
    "task_status": {
      "type": "string",
      "enum": ["queued", "running", "waiting_approval", "completed", "failed", "canceled"]
    }
  },
  "additionalProperties": false
}
