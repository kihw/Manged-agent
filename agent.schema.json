{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/schemas/agent.schema.json",
  "title": "AgentDefinition",
  "type": "object",
  "required": [
    "agent_id",
    "version",
    "system_prompt",
    "tools",
    "policy_profile",
    "limits"
  ],
  "properties": {
    "agent_id": {"type": "string", "minLength": 1},
    "version": {"type": "string", "minLength": 1},
    "description": {"type": "string"},
    "system_prompt": {"type": "string", "minLength": 1},
    "tools": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "minLength": 1}
    },
    "allowed_mcp_servers": {
      "type": "array",
      "items": {"$ref": "./mcp-server.schema.json"},
      "default": []
    },
    "policy_profile": {"type": "string", "minLength": 1},
    "limits": {
      "type": "object",
      "required": [
        "max_iterations",
        "max_input_tokens",
        "max_output_tokens",
        "max_cost_usd",
        "max_duration_sec"
      ],
      "properties": {
        "max_iterations": {"type": "integer", "minimum": 1},
        "max_input_tokens": {"type": "integer", "minimum": 1},
        "max_output_tokens": {"type": "integer", "minimum": 1},
        "max_cost_usd": {"type": "number", "minimum": 0},
        "max_duration_sec": {"type": "integer", "minimum": 1}
      },
      "additionalProperties": false
    },
    "approval_rules": {
      "type": "object",
      "properties": {
        "require_human_for": {
          "type": "array",
          "items": {"type": "string"},
          "default": []
        }
      },
      "additionalProperties": false,
      "default": {}
    },
    "metadata": {
      "type": "object",
      "additionalProperties": {"type": ["string", "number", "boolean", "null"]}
    }
  },
  "additionalProperties": false
}
