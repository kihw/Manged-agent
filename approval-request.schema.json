{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/schemas/approval-request.schema.json",
  "title": "ApprovalRequest",
  "type": "object",
  "required": ["approval_id", "task_id", "trace_id", "step_id", "status", "requested_by", "requested_at", "reason"],
  "properties": {
    "approval_id": {
      "type": "string",
      "pattern": "^apr_[a-z0-9]{8,64}$"
    },
    "task_id": {
      "type": "string",
      "pattern": "^task_[a-z0-9]{8,64}$"
    },
    "trace_id": {
      "type": "string",
      "pattern": "^trace_[a-z0-9]{8,64}$"
    },
    "step_id": {
      "type": "string",
      "pattern": "^step_[a-z0-9]{8,64}$"
    },
    "status": {
      "$ref": "#/$defs/task_status"
    },
    "requested_by": {
      "type": "string",
      "minLength": 1
    },
    "requested_at": {
      "type": "string",
      "format": "date-time"
    },
    "approved_by": {
      "type": ["string", "null"]
    },
    "approved_at": {
      "type": ["string", "null"],
      "format": "date-time"
    },
    "reason": {
      "type": "string",
      "minLength": 1
    },
    "comment": {
      "type": "string"
    }
  },
  "$defs": {
    "task_status": {
      "type": "string",
      "enum": ["queued", "running", "waiting_approval", "completed", "failed", "canceled"]
    }
  },
  "additionalProperties": false
}
