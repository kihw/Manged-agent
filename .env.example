# Application
APP_ENV=dev

# Data stores
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/managed_agents
REDIS_URL=redis://redis:6379/0

# LLM / Codex
CODEX_AUTH_MODE=auto
CODEX_API_BASE_URL=https://api.openai.com
CODEX_API_KEY=

# OAuth
OAUTH_CLIENT_ID=
OAUTH_CLIENT_SECRET=
OAUTH_REDIRECT_URI=http://localhost:8080/v1/auth/oauth/callback
OAUTH_TOKEN_URL=
OAUTH_AUTH_URL=

# Observability
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317

# Grafana (service grafana)
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=admin

# Postgres (service postgres)
POSTGRES_DB=managed_agents
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
